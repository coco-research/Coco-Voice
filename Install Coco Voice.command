#!/bin/bash
# Double-click this file to install Coco Voice.
#
# If macOS blocks it ("cannot be opened because it is from an unidentified
# developer"), right-click this file in Finder, choose Open, then Open again —
# you only need to do that once.
curl -fsSL https://raw.githubusercontent.com/coco-research/Coco-Voice/main/install.sh | bash
echo ""
echo "Press Return to close this window."
read -r _
